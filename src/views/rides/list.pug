extends ../layout

block title
    title Atracciones - Tykuna

block content 
    main
        if user
            h1 Hola #{user.name}
        div.header-actions
            h1 Atracciones del Parque
            if(user && user.role==="admin")
                a.btn(href="/rides/create") + Añadir Atracción

        section.rides-list
            each ride in rides 
                include rideCard